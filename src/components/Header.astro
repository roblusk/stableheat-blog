---
// Site header with brand, nav, and date/location strip.
---
<header class="site-header">
  <div class="container">
    <a class="brand" href="/">
      <span class="brand-mark">
        <i class="fa-solid fa-temperature-half" aria-hidden="true"></i>
      </span>
      <span class="brand-name">Stable<span>Heat</span></span>
    </a>
    <nav class="site-nav">
      <a href="/">Blog</a>
      <a href="/about">About</a>
      <a class="nav-cta" href="/shop">Shop StableHeat</a>
    </nav>
  </div>
</header>

<div class="masthead-strip">
  <div class="container">
    <span><strong>StableHeat Insights</strong> · Electric radiant heating, underfloor warmth, and the places it makes better.</span>
    <span>St. Louis, MO</span>
  </div>
</div>
