---
import { applications } from '../data/applications';
import { path } from '../utils/url';

const stripTrailing = (s: string) => s.replace(/\/$/, '');
const currentPath = stripTrailing(Astro.url.pathname);
---
<nav class="app-strip" aria-label="Browse posts by application">
  <div class="container">
    <ul>
      {applications.map((app) => {
        const href = path(`/category/${app.slug}`);
        const isActive = currentPath === stripTrailing(href);
        return (
          <li>
            <a href={href} class={isActive ? 'active' : ''} aria-current={isActive ? 'page' : undefined}>
              <span class="app-icon"><i class={`fa-solid fa-${app.icon}`} aria-hidden="true"></i></span>
              <span class="app-label">{app.name}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>
