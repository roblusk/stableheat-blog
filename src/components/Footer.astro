---
import { path } from '../utils/url';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div>
      <a class="brand" href={path('/')} style="margin-bottom: 12px;">
        <span class="brand-mark">
          <i class="fa-solid fa-temperature-half" aria-hidden="true"></i>
        </span>
        <span class="brand-name">Stable<span>Heat</span></span>
      </a>
      <p style="margin: 12px 0 0; max-width: 32ch;">Self-regulating electric radiant heating for floors, snowmelt, marine, and industrial applications. Formerly STEP Heat.</p>
    </div>
    <div>
      <h5>Applications</h5>
      <ul>
        <li><a href="https://stepheat.com" target="_blank" rel="noopener">Warmfloor</a></li>
        <li><a href="https://stepheat.com" target="_blank" rel="noopener">Snowmelt</a></li>
        <li><a href="https://stepheat.com" target="_blank" rel="noopener">Marine</a></li>
        <li><a href="https://stepheat.com" target="_blank" rel="noopener">Industrial / OEM</a></li>
      </ul>
    </div>
    <div>
      <h5>Blog</h5>
      <ul>
        <li><a href={path('/')}>Latest stories</a></li>
        <li><a href={path('/about')}>About</a></li>
        <li><a href={path('/posts/electric-vs-hydronic')}>Guides</a></li>
        <li><a href={path('/posts/self-regulating-tech')}>Technology</a></li>
      </ul>
    </div>
    <div>
      <h5>Contact</h5>
      <ul>
        <li>St. Louis, MO</li>
        <li><a href="tel:+13142025540">314.202.5540</a></li>
        <li><a href="mailto:sales@stableheat.com">sales@stableheat.com</a></li>
        <li><a href="https://stepheat.com" target="_blank" rel="noopener">stableheat.com</a></li>
      </ul>
    </div>
    <div class="footer-bottom" style="grid-column: 1 / -1;">
      <span>© {year} StableHeat. All rights reserved.</span>
      <span>Feel the future of warmth.</span>
    </div>
  </div>
</footer>
