---
import type { CollectionEntry } from 'astro:content';
import Thumb from './Thumb.astro';

export interface Props {
  post: CollectionEntry<'posts'>;
  variant?: 'feature' | 'card' | 'list';
}
const { post, variant = 'card' } = Astro.props;
const { data, slug } = post;
const href = `/posts/${slug}`;
const dateStr = data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
{variant === 'feature' && (
  <article class="feature-card">
    <a href={href} class="post-thumb">
      <Thumb variant={data.thumbVariant} icon={data.thumbIcon} />
    </a>
    <div class="post-body">
      <div class="post-meta">{data.category} <span class="dot">·</span> {dateStr} <span class="dot">·</span> {data.readTime}</div>
      <h3>{data.title}</h3>
      <p>{data.excerpt}</p>
      <a class="read-more" href={href}>Read the story →</a>
    </div>
  </article>
)}

{variant === 'card' && (
  <article class="post-card">
    <a href={href}>
      <div class="post-thumb">
        <Thumb variant={data.thumbVariant} icon={data.thumbIcon} />
      </div>
      <div class="post-body">
        <div class="post-meta">{data.category} <span class="dot">·</span> {dateStr}</div>
        <h3>{data.title}</h3>
        <p>{data.excerpt}</p>
        <span class="read-more">Read →</span>
      </div>
    </a>
  </article>
)}

{variant === 'list' && (
  <a class="post-list-item" href={href}>
    <div class="post-list-thumb">
      <Thumb variant={data.thumbVariant} icon={data.thumbIcon} />
    </div>
    <div class="post-list-body">
      <h4>{data.title}</h4>
      <div class="meta">{data.category} · {dateStr}</div>
    </div>
  </a>
)}
